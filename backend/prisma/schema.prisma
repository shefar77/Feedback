generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model FeedbackEvent {
  id               Int      @id @default(autoincrement())
  placeId          String
  bizName          String
  category         String
  lang             String
  rating           Int
  finalText        String
  suggestionIndex  Int
  edited           Boolean
  createdAt        DateTime @default(now())
}